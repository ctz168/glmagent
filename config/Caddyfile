# ============================================================
# Caddy Configuration for GLM Agent Engine
# Replicated from Z.ai Container Runtime
#
# Uses {$FC_CUSTOM_LISTEN_PORT:81} to match the real production
# environment variable FC_CUSTOM_LISTEN_PORT (default: 81).
# ============================================================

{$FC_CUSTOM_LISTEN_PORT:81} {
    # Security headers
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    # Health check endpoint (public, simple response for orchestrator)
    handle /health {
        respond "OK" 200
    }

    # Static landing page
    handle / {
        root * /app/static
        try_files {path} /index.html
    }

    # Static assets (logo, etc.)
    handle /logo.svg {
        root * /app/static
        file_server
    }

    # Agent Engine API (proxy to FastAPI backend on :12600)
    handle /v1/* {
        reverse_proxy localhost:12600
    }

    # Agent Engine Swagger docs
    handle /docs {
        reverse_proxy localhost:12600
    }

    # Agent Engine ReDoc
    handle /redoc {
        reverse_proxy localhost:12600
    }

    # OpenAPI schema
    handle /openapi.json {
        reverse_proxy localhost:12600
    }

    # File download endpoint
    handle /files/* {
        reverse_proxy localhost:12600
    }

    # WebSocket support (for SSE streaming and real-time features)
    handle /ws/* {
        reverse_proxy localhost:12600 {
            header_up Connection {>Connection}
            header_up Upgrade {>Upgrade}
        }
    }

    # Logging
    log {
        output stderr
        format console
        level INFO
    }
}

# Internal services for mini-services
# These are started by start.sh for sub-services in mini-services/
# Port 19005 → Main Next.js app (port 3000)
:19005 {
    reverse_proxy localhost:3000
}

# Port 19006 → Additional mini-service (port 3001)
:19006 {
    reverse_proxy localhost:3001
}
