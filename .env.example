# ============================================================
# GLM Agent Engine Configuration
# Copy this file to .env and customize for your environment.
# These variables mirror the real Z.ai Kata Container runtime.
# ============================================================

# === Z.ai Backend API ===
# The backend AI service endpoint (the actual LLM provider)
ZAI_BASE_URL=http://host.docker.internal:8080/v1
ZAI_API_KEY=your-api-key

# === IM Gateway Metadata (set by orchestrator in production) ===
# These are injected by the IM gateway; leave empty for local dev
ZAI_CHAT_ID=
ZAI_TOKEN=
ZAI_USER_ID=

# === Server Configuration ===
# Internal agent engine port
ENGINE_PORT=12600
# Public HTTP port (Caddy, set by orchestrator)
FC_CUSTOM_LISTEN_PORT=81

# === Container Metadata ===
# These are set by the orchestrator in production; customize for local dev
FC_REGION=local
FC_INSTANCE_ID=glm-agent-dev-001
FC_FUNCTION_NAME=glm-agent-local
FC_CONTAINER_ID=
FC_ACCOUNT_ID=
FC_FUNCTION_HANDLER=index.handler
FC_FUNCTION_MEMORY_SIZE=8192

# === Platform ===
SIGMA_APP_NAME=
CLAWHUB_DISABLE_TELEMETRY=1
KATA_CONTAINER=false
CLAWHUB_WORKDIR=/home/z/my-project

# === Database ===
# SQLite (default, for local dev / single-container):
DATABASE_URL=file:/home/z/my-project/db/custom.db
# MySQL (for production with external DB):
# DATABASE_URL=mysql+aiomysql://user:password@mysql:3306/glm_agent

# === Redis ===
# Leave empty to disable Redis (uses in-memory fallback)
REDIS_URL=
# Redis with a Docker Compose service:
# REDIS_URL=redis://redis:6379/0
# Redis with password:
# REDIS_URL=redis://:yourpassword@redis:6379/0

# === Authentication ===
# Set to "true" to require API key auth on /v1/* endpoints
AUTH_ENABLED=false

# === Datadog Tracing & Observability ===
DD_TRACE_ENABLED=false
DD_SERVICE=glm-agent-engine
DD_ENV=development
# DD_DOGSTATSD_URL=udp://datadog:8125
# DD_TRACE_AGENT_URL=http://datadog:8126

# === Logging ===
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# === Timeouts ===
# Session timeout in seconds (idle session cleanup)
SESSION_TIMEOUT=3600
# Tool/skill execution timeout in seconds
TOOL_EXECUTION_TIMEOUT=300
# Engine proxy read/write timeout (used by Caddy)
ENGINE_READ_TIMEOUT=60s
ENGINE_WRITE_TIMEOUT=60s

# === Upload ===
# Maximum upload size for file uploads (in bytes)
# 104857600 = 100MB
MAX_UPLOAD_SIZE=104857600

# === Mini-Services ===
# Next.js dev server port (proxied via Caddy :19005)
NEXTJS_PORT=3000
# Secondary mini-service port (proxied via Caddy :19006)
MINI_SERVICE_2_PORT=3001
